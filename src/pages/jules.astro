---
import Base from '../layouts/Base.astro';
import JsonLd from '../components/JsonLd.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is Jules?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Jules is an AI operational system built on Claude Code that thinks with you and then executes across every domain of a solo business — strategy, software, content, research, deploys, and reporting.',
      },
    },
    {
      '@type': 'Question',
      name: 'How is Jules different from other AI tools?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most AI tools help you do tasks faster. Jules helps you think through decisions first — challenging assumptions, running adversarial review, decomposing problems — then executes across software, content, research, and operations in one system with continuous context.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I build something like Jules?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Jules is built entirely with Claude Code\'s built-in features: CLAUDE.md files, skills, hooks, and MCP servers. No external frameworks. The full source is available on GitHub.',
      },
    },
  ],
};
---

<Base
  title="Jules"
  description="Jules is an AI system that thinks with you, then executes across everything. Strategy, software, content, research, deploys — one system, one context. Open source."
  schema={faqSchema}
>
  <div class="container">

    <!-- Hero -->
    <section class="jules-hero">
      <h1>Strategic Thinking + Execution.</h1>
      <p>
        Think through decisions strategically with AI.<br/>
        Execute the rest automatically.
      </p>
      <div class="jules-pills">
        <span class="jules-pill">Think</span>
        <span class="jules-pill">Write</span>
        <span class="jules-pill">Build</span>
        <span class="jules-pill">Deploy</span>
      </div>
      <p class="jules-hero-link">
        Open source: <a href="https://github.com/jonathanmalkin/jules">github.com/jonathanmalkin/jules</a>
      </p>
    </section>

    <!-- The Problem -->
    <section class="jules-section">
      <h2>The Problem</h2>
      <p>
        Running a business is a continuous loop of thinking, deciding, and executing
        across a dozen domains. AI helps you deploy faster but speed on individual
        tasks doesn't move the ball forward.
      </p>
      <p>
        You still think alone, then hand work off to different tools and lose context
        at every boundary. The hard part was always thinking clearly and keeping
        everything connected.
      </p>
    </section>

    <!-- What Jules Does -->
    <section class="jules-section">
      <h2>What Jules Does</h2>

      <div class="jules-two-col">
        <div class="jules-col">
          <h3>Thinks with you</h3>
          <p>
            Strategy, decisions, challenging assumptions, decomposition.
            Jules doesn't generate answers, it spars with you to find better ones.
            Socratic dialogue, adversarial review. The stuff you'd get from a cofounder
            if you had one.
          </p>
        </div>
        <div class="jules-col">
          <h3>Then executes</h3>
          <p>
            Software development, content pipelines, deep research, deploys,
            analytics reporting, scheduling, all in one system with the same context.
            Decisions from the thinking phase flow straight into execution.
          </p>
        </div>
      </div>
    </section>

    <!-- Workflows -->
    <section class="jules-section">
      <h2>The Loop in Action</h2>

      <div class="jules-workflow">
        <div class="jules-workflow-item">
          <div class="jules-workflow-label">Think</div>
          <div class="jules-workflow-content">
            <strong>"I need to figure out my brand positioning."</strong>
            Jules challenges the framing, asks one question at a time, runs adversarial review
            on the recommendation. We land on a direction together.
          </div>
        </div>
        <div class="jules-workflow-item">
          <div class="jules-workflow-label">Build</div>
          <div class="jules-workflow-content">
            <strong>"Now implement it."</strong>
            Jules writes the homepage copy, updates the meta tags, adjusts the CSS,
            takes screenshots, iterates until it's right.
          </div>
        </div>
        <div class="jules-workflow-item">
          <div class="jules-workflow-label">Ship</div>
          <div class="jules-workflow-content">
            <strong>"Deploy it."</strong>
            Build passes. Site goes live. Jules verifies the deployment. Session report
            captures what changed and why.
          </div>
        </div>
      </div>

      <div class="jules-workflow">
        <div class="jules-workflow-item">
          <div class="jules-workflow-label">Think</div>
          <div class="jules-workflow-content">
            <strong>"This article isn't landing. What's wrong?"</strong>
            Jules reads the draft, identifies structural problems, proposes a different angle.
            We debate it.
          </div>
        </div>
        <div class="jules-workflow-item">
          <div class="jules-workflow-label">Write</div>
          <div class="jules-workflow-content">
            <strong>"Rewrite it with that framing."</strong>
            New draft, same voice calibration, same style guide. Runs a slop audit
            to catch AI writing patterns.
          </div>
        </div>
        <div class="jules-workflow-item">
          <div class="jules-workflow-label">Distribute</div>
          <div class="jules-workflow-content">
            <strong>"Post it."</strong>
            Jules handles the distribution from one command. Publishes to the site,
            adapts for Reddit and LinkedIn, queues the cross-posts.
          </div>
        </div>
      </div>
    </section>

    <!-- Under the Hood -->
    <section class="jules-section">
      <h2>Under the Hood</h2>
      <p class="jules-section-sub">For the builders who want to know how it's made.</p>
    </section>
  </div>

  <!-- Dashboard -->
  <section class="dashboard">
    <div class="stat-grid">
      <div class="stat-card">
        <div class="stat-number">18</div>
        <div class="stat-label">Skills</div>
        <div class="stat-detail">/think, /build, /write, /research, /debug. Multi-phase workflows, not single prompts.</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">5</div>
        <div class="stat-label">Hooks</div>
        <div class="stat-detail">Unified safety guard, RTK token optimization, desktop notifications, session-start sync.</div>
      </div>
      <div class="stat-card">
        <div class="stat-number always-on">ON</div>
        <div class="stat-label">Cloud Batch</div>
        <div class="stat-detail">Overnight: daily retro, morning briefing, email fetch. Ready before the laptop opens.</div>
      </div>
      <div class="stat-card">
        <div class="stat-number always-on">ON</div>
        <div class="stat-label">Telegram</div>
        <div class="stat-detail">Interactive access from phone. Cloud web sessions when the laptop is closed.</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">60-90%</div>
        <div class="stat-label">Token Savings</div>
        <div class="stat-detail">RTK (Rust Token Killer) rewrites dev commands for massive context savings.</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">&lt;500</div>
        <div class="stat-label">Lines in CLAUDE.md</div>
        <div class="stat-detail">Identity, routing, authority, safety. One file, always loaded.</div>
      </div>
    </div>
  </section>

  <div class="container">

    <!-- Architecture -->
    <section class="jules-section">
      <h3>Architecture</h3>
      <p style="color: var(--color-text-muted); margin-bottom: 1rem;">Mac for interactive development. Cloud for scheduled tasks. No VPS, no Docker, no daemons.</p>
      <div class="hybrid-arch">
        <div class="hybrid-node hybrid-mac">
          <div class="hybrid-label">Mac</div>
          <div class="hybrid-detail">Interactive dev</div>
        </div>
        <div class="hybrid-arrow">&rarr;</div>
        <div class="hybrid-node hybrid-github">
          <div class="hybrid-label">Cloud</div>
          <div class="hybrid-detail">Overnight batch</div>
        </div>
        <div class="hybrid-arrow">&rarr;</div>
        <div class="hybrid-node hybrid-vps">
          <div class="hybrid-label">Telegram</div>
          <div class="hybrid-detail">Phone access</div>
        </div>
        <div class="hybrid-arrow">&rarr;</div>
        <div class="hybrid-node hybrid-phone">
          <div class="hybrid-label">Cloud Web</div>
          <div class="hybrid-detail">Remote sessions</div>
        </div>
      </div>
    </section>

    <!-- Version Evolution -->
    <section class="jules-section">
      <h3>Evolution</h3>
      <div class="version-strip">
        <div class="version-col">
          <div class="version-tag">v1</div>
          <div class="version-title">Identity + Skills</div>
          <p>Personality, voice registers, decision authority. CLAUDE.md files and early skill workflows.</p>
        </div>
        <div class="version-col">
          <div class="version-tag">v2-v3</div>
          <div class="version-title">Automation + Planning</div>
          <p>Container infrastructure, scheduled jobs, planning dispatch, research agents, security hooks.</p>
        </div>
        <div class="version-col version-col-current">
          <div class="version-tag">v4</div>
          <div class="version-title">Simplification</div>
          <p>32 skills became 18. 15 hooks became 5. VPS eliminated. Same power, half the parts.</p>
        </div>
      </div>
    </section>

    <!-- Build Your Own -->
    <section class="jules-section">
      <h2>Build Your Own</h2>
      <div class="getting-started">
        <p class="getting-started-lead">You don't need dozens of configurations to start. Try this one prompt:</p>
        <pre><code>claude "Read my codebase. Create a .claude/CLAUDE.md that describes
the project, key conventions, and common workflows. Then create
one skill in .claude/skills/ for the task I do most often."</code></pre>
        <p class="getting-started-sub">
          That's it. One CLAUDE.md and one skill. Build up from there.
          <br>Full source: <a href="https://github.com/jonathanmalkin/jules">github.com/jonathanmalkin/jules</a>
        </p>
      </div>
    </section>

    <section class="jules-section">
      <h2>Read More</h2>
      <p>
        I write about how Jules works, what I've learned building it, and how the system evolves: <a href="/articles/">Articles &rarr;</a>
      </p>
    </section>

  </div>
</Base>
