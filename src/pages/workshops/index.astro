  .ws-agenda-title {
    flex: 1;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .ws-agenda-chevron {
    flex-shrink: 0;
    font-size: 1.1rem;
    color: var(--color-text-muted);
    transition: transform 0.2s;
    display: inline-block;
  }

  .ws-agenda-item.expanded .ws-agenda-chevron {
    transform: rotate(90deg);
  }

  .ws-agenda-detail {
    display: none;
    padding: 0 1rem 0.75rem 1rem;
    padding-left: calc(1rem + 7rem + 0.75rem);
  }

  .ws-agenda-detail p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 0;
    line-height: 1.5;
  }

  .ws-agenda-item.expanded .ws-agenda-detail {
    display: block;
  }

  /* Break items */
  .ws-agenda-break {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.75rem 0.75rem 0.75rem 1rem;
