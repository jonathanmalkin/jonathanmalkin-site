</style>

<script>
  // Tab switching
  document.querySelectorAll('.ws-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const tier = tab.dataset.tier;

      document.querySelectorAll('.ws-tab').forEach(t => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');

      document.querySelectorAll('.ws-panel').forEach(p => {
        p.classList.remove('active');
      });
      const panel = document.querySelector(`[data-panel="${tier}"]`);
      if (panel) {
        panel.classList.add('active');
        panel.setAttribute('tabindex', '-1');
        panel.focus({ preventScroll: true });
      }
    });
  });

  // Agenda item expand/collapse
  document.querySelectorAll('.ws-agenda-item[data-expandable] .ws-agenda-header').forEach(header => {
    header.addEventListener('click', () => {
      const item = header.closest('.ws-agenda-item');
      const expanded = item.classList.toggle('expanded');
      header.setAttribute('aria-expanded', String(expanded));
    });
  });
</script>
