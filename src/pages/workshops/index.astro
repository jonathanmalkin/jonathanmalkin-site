  /* Responsive tabs */
  @media (max-width: 640px) {
    .ws-tab {
      font-size: 0.8rem;
      padding: 0.6rem 0.5rem;
    }

    .ws-agenda-time {
      width: 5.5rem;
      font-size: 0.75rem;
    }

    .ws-agenda-detail {
      padding-left: calc(1rem + 5.5rem + 0.75rem);
    }

    .ws-agenda-title {
      font-size: 0.9rem;
    }
