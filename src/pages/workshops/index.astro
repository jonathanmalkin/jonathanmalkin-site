    background: none;
    font-family: var(--font-body);
    font-size: inherit;
    color: var(--color-text);
    cursor: pointer;
    text-align: left;
    transition: background 0.15s;
  }

  .ws-agenda-header:hover {
    background: var(--color-surface);
  }

  .ws-agenda-header:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }

  .ws-agenda-time {
    flex-shrink: 0;
    width: 7rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
