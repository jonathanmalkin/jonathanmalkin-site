  }

  .ws-worksheet-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.35rem;
  }

  .ws-worksheet-tiers {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    background: var(--color-code-bg);
    padding: 0.1em 0.4em;
    border-radius: 3px;
    white-space: nowrap;
  }

  .ws-worksheet p {
