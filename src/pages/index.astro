---
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Jonathan Malkin',
  jobTitle: 'AI Builder & Solo Founder',
  description: 'Software development and technical advisory. Building assessment tools, an open-source AI framework, and educational content. Solo founder of Open Door Learning LLC.',
  url: 'https://builtwithjon.com',
  sameAs: [
    'https://github.com/jonathanmalkin',
    'https://www.reddit.com/user/jonathanmalkin/',
    'https://x.com/builtwithjon',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Jonathan Malkin',
  url: 'https://builtwithjon.com',
  description: 'AI builder, solo founder. Writing about Claude Code, AI agents, and building where mainstream tech won\'t.',
};
---

<Base
  title="Jonathan Malkin"
  description="Software development and technical advisory. Building assessment tools, an open-source AI framework, and educational content. Writing about Claude Code, AI agents, and solo founding with AI."
  schema={personSchema}
>
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <!-- Hero -->
  <section class="hero container">
    <p class="hero-label">Solo AI Builder &middot; Austin, TX</p>
    <h1>My business partner is a fox<br>who never sleeps.</h1>
    <p class="subtitle">
      I left enterprise tech to build a solo business. Then I built <a href="/jules/">Jules</a>,
      an AI system that runs most of it for me. Here's what's inside.
    </p>
    <div class="hero-links">
      <a href="/jules/" class="hero-btn">See the System</a>
      <a href="/articles/" class="hero-btn hero-btn-outline">Read the Articles</a>
      <a href="#subscribe" class="hero-btn hero-btn-outline">Subscribe</a>
    </div>
  </section>

  <!-- Dashboard: Jules System Stats -->
  <section class="dashboard">
    <div class="dashboard-header">
      <h2>Jules System <span class="pulse">LIVE</span> <span class="version-badge">v3</span></h2>
      <p class="dashboard-sub">A Claude Code system that runs a solo business. Here's what's inside.</p>
    </div>

    <div class="stat-grid">
      <div class="stat-card">
        <div class="stat-number">32</div>
        <div class="stat-label">Skills</div>
        <div class="stat-detail">Multi-phase workflows with routing logic, model selection, and skill-to-skill chaining</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">21</div>
        <div class="stat-label">Rules</div>
        <div class="stat-detail">Always-on context: request routing, credential lookup, token efficiency, research standards</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">14</div>
        <div class="stat-label">Hooks</div>
        <div class="stat-detail">Deterministic middleware: safety guards, output compression, credential protection</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">9</div>
        <div class="stat-label">Scheduled Jobs</div>
        <div class="stat-detail">VPS running 24/7: daily retro, morning briefings, auth heartbeat, email fetch</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">4</div>
        <div class="stat-label">Agents</div>
        <div class="stat-detail">Specialized subagents: code review, quiz testing, content authoring, codebase exploration</div>
      </div>
      <div class="stat-card">
        <div class="stat-number always-on">ON</div>
        <div class="stat-label">Slack Daemon</div>
        <div class="stat-detail">24/7 phone access: message from anywhere, autonomous task dispatch</div>
      </div>
    </div>
  </section>

  <!-- Version Evolution -->
  <section class="container" style="margin-bottom: 3rem;">
    <h2>How Jules Evolved</h2>
    <div class="version-strip">
      <div class="version-col">
        <div class="version-tag">v1</div>
        <div class="version-title">Identity + Skills</div>
        <p>Personality, voice registers, decision authority. CLAUDE.md files and early skill workflows.</p>
      </div>
      <div class="version-col">
        <div class="version-tag">v2</div>
        <div class="version-title">Container + Automation</div>
        <p>VPS with Docker, cron jobs, Slack daemon, morning briefings. Jules works while I sleep.</p>
      </div>
      <div class="version-col version-col-current">
        <div class="version-tag">v3</div>
        <div class="version-title">Planning + Research + Security</div>
        <p>Goal decomposition, dispatch system, parallel research agents, security hooks, context reload.</p>
      </div>
    </div>
  </section>

  <!-- Architecture Diagram -->
  <section class="container" style="margin-bottom: 3rem;">
    <h2>How It Works</h2>
    <div class="layer-stack">
      <div class="layer-bar layer-products">
        <span class="layer-icon">&#9881;</span>
        <div>
          <div class="layer-name">Products</div>
          <div class="layer-desc">Quiz app, website, content pipeline. Applications the system builds and ships.</div>
        </div>
      </div>
      <div class="layer-bar layer-automation">
        <span class="layer-icon">&#9200;</span>
        <div>
          <div class="layer-name">Automation</div>
          <div class="layer-desc">9 scheduled jobs, Slack daemon, dispatch system. Runs 24/7 on a VPS.</div>
        </div>
      </div>
      <div class="layer-bar layer-infra">
        <span class="layer-icon">&#128736;</span>
        <div>
          <div class="layer-name">Infrastructure</div>
          <div class="layer-desc">14 hooks, Docker container, credential wiring, auth heartbeat.</div>
        </div>
      </div>
      <div class="layer-bar layer-config">
        <span class="layer-icon">&#9881;</span>
        <div>
          <div class="layer-name">Configuration</div>
          <div class="layer-desc">21 rules, 32 skills, 4 agents. Request routing, research pipelines, planning.</div>
        </div>
      </div>
      <div class="layer-bar layer-state">
        <span class="layer-icon">&#128203;</span>
        <div>
          <div class="layer-name">Operational State</div>
          <div class="layer-desc">Terrain, daily briefings, decision queue. Live working state that evolves daily.</div>
        </div>
      </div>
      <div class="layer-bar layer-identity">
        <span class="layer-icon">&#129418;</span>
        <div>
          <div class="layer-name">Identity</div>
          <div class="layer-desc">Agent personality, user context, goals, voice registers, decision authority.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Hybrid Architecture -->
  <section class="container" style="margin-bottom: 3rem;">
    <h2>Hybrid Architecture</h2>
    <p style="color: var(--color-text-muted); margin-bottom: 1rem;">Mac for interactive development. Container for 24/7 automation. Memory synced through git.</p>
    <div class="hybrid-arch">
      <div class="hybrid-node hybrid-mac">
        <div class="hybrid-label">Mac</div>
        <div class="hybrid-detail">Interactive dev</div>
      </div>
      <div class="hybrid-arrow">&rarr;</div>
      <div class="hybrid-node hybrid-github">
        <div class="hybrid-label">GitHub</div>
        <div class="hybrid-detail">Memory sync</div>
      </div>
      <div class="hybrid-arrow">&rarr;</div>
      <div class="hybrid-node hybrid-vps">
        <div class="hybrid-label">VPS Container</div>
        <div class="hybrid-detail">Cron + Slack</div>
      </div>
      <div class="hybrid-arrow">&rarr;</div>
      <div class="hybrid-node hybrid-phone">
        <div class="hybrid-label">Phone</div>
        <div class="hybrid-detail">Slack access</div>
      </div>
    </div>
  </section>

  <!-- A Day with Jules -->
  <section class="container" style="margin-bottom: 3rem;">
    <h2>A Day with Jules</h2>
    <div class="timeline">
      <div class="timeline-item">
        <div class="timeline-time">Every 1 min</div>
        <div class="timeline-content">
          <strong>Git sync</strong> &mdash; Mac and container stay in lock-step via auto-pull.
        </div>
      </div>
      <div class="timeline-item">
        <div class="timeline-time">Hourly</div>
        <div class="timeline-content">
          <strong>Auth heartbeat + email fetch</strong> &mdash; Validates credentials, classifies failures (auth vs. API outage vs. network). Fetches inbox.
        </div>
      </div>
      <div class="timeline-item">
        <div class="timeline-time">Sessions</div>
        <div class="timeline-content">
          <strong>Real-time collaboration</strong> &mdash; Interactive terminal or VS Code. Skills route requests, hooks guard every tool call.
        </div>
      </div>
      <div class="timeline-item">
        <div class="timeline-time">4:00 PM</div>
        <div class="timeline-content">
          <strong>Afternoon scan</strong> &mdash; Content opportunities, engagement check, stale item review.
        </div>
      </div>
      <div class="timeline-item">
        <div class="timeline-time">8:00 PM</div>
        <div class="timeline-content">
          <strong>Daily retro</strong> &mdash; Analyzes the day's sessions, cross-references config, applies self-improvements. Moved from 3 AM to dodge the Anthropic API outage window.
        </div>
      </div>
      <div class="timeline-item">
        <div class="timeline-time">Midnight</div>
        <div class="timeline-content">
          <strong>Morning orchestrator</strong> &mdash; Waits for retro completion, assembles next-day briefing. Ready before the laptop opens.
        </div>
      </div>
      <div class="timeline-item">
        <div class="timeline-time">Wrap-up</div>
        <div class="timeline-content">
          <strong>Session report</strong> &mdash; Commit code, update memory, run quality checks, flag publishable content.
        </div>
      </div>
      <div class="timeline-item">
        <div class="timeline-time">Anytime</div>
        <div class="timeline-content">
          <strong>Slack from phone</strong> &mdash; Message Jules from anywhere. Autonomous task dispatch, research queuing, URL processing.
        </div>
      </div>
    </div>
  </section>

  <!-- v3 Capabilities -->
  <section class="container" style="margin-bottom: 3rem;">
    <h2>What's New in v3</h2>
    <div class="capabilities-grid">
      <div class="capability-card">
        <strong>Goal Decomposition</strong>
        <p>Socratic dialogue breaks life-level goals into executable task queues with dependency tracking.</p>
      </div>
      <div class="capability-card">
        <strong>Planning Dispatch</strong>
        <p>Triage tasks by ownership (autonomous, interactive, manual), batch decisions, dispatch subagents.</p>
      </div>
      <div class="capability-card">
        <strong>Deep Research</strong>
        <p>Parallel Haiku agents gather context. Sonnet synthesizes. Full audit trails with source confidence tiers.</p>
      </div>
      <div class="capability-card">
        <strong>Security Layer</strong>
        <p>3 hooks guard credentials, block dangerous commands, and sanitize outbound content. Deterministic, not probabilistic.</p>
      </div>
      <div class="capability-card">
        <strong>Context Reload</strong>
        <p>Deterministic session restoration from plans, memory, and operational state. No "where were we?" syndrome.</p>
      </div>
    </div>
  </section>

  <!-- Three Stories -->
  <section class="container" style="margin-bottom: 3rem;">
    <h2>What I Write About</h2>
    <div class="story-grid">
      <a href="/jules/" class="story-card story-card-1">
        <div class="story-num">Story 1</div>
        <h3>The Setup Is The Product</h3>
        <p>Claude Code infrastructure, skills, hooks, rules, workflows. The system itself is the work product.</p>
      </a>
      <div class="story-card story-card-2">
        <div class="story-num">Story 2</div>
        <h3>Build Where They Won't</h3>
        <p>The taboo-to-mainstream thesis. Why underserved communities are the next frontier for AI builders.</p>
      </div>
      <div class="story-card story-card-3">
        <div class="story-num">Story 3</div>
        <h3>Solo Founder + AI</h3>
        <p>One person with AI doing what used to require a team. The practical reality, not the hype.</p>
      </div>
    </div>
  </section>

  <!-- Getting Started -->
  <section class="container" style="margin-bottom: 3rem;">
    <h2>Build Your Own</h2>
    <div class="getting-started">
      <p class="getting-started-lead">You don't need 80+ configurations to start. Try this one prompt:</p>
      <pre><code>claude "Read my codebase. Create a .claude/CLAUDE.md that describes
the project, key conventions, and common workflows. Then create
one skill in .claude/skills/ for the task I do most often."</code></pre>
      <p class="getting-started-sub">
        That's it. One CLAUDE.md and one skill. Build up from there.
        <br>Full source: <a href="https://github.com/jonathanmalkin/jules">github.com/jonathanmalkin/jules</a>
        &middot; <a href="/jules/">How Jules works &rarr;</a>
      </p>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="container" style="margin-bottom: 3rem;">
    <div class="section-heading">
      <h2>Latest Articles</h2>
      <a href="/articles/">View all &rarr;</a>
    </div>
    {articles.map((article) => (
      <ArticleCard
        title={article.data.title}
        slug={article.id}
        date={article.data.date}
        description={article.data.description}
        story={article.data.story}
      />
    ))}
  </section>
</Base>
