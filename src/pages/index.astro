---
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Jonathan Malkin',
  jobTitle: 'AI Builder & Solo Founder',
  description: 'I build AI systems for communities mainstream tech ignores. Solo founder of Open Door Learning LLC.',
  url: 'https://jonathanmalkin.com',
  sameAs: [
    'https://github.com/jonathanmalkin',
    'https://www.reddit.com/user/jonathanmalkin/',
    'https://x.com/builtwithjon',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Jonathan Malkin',
  url: 'https://jonathanmalkin.com',
  description: 'AI builder, solo founder. Writing about Claude Code, AI agents, and building where mainstream tech won\'t.',
};
---

<Base
  title="Jonathan Malkin"
  description="I build AI systems for communities mainstream tech ignores. Writing about Claude Code, AI agents, and building as a solo founder with AI."
  schema={personSchema}
>
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <!-- Hero -->
  <section class="hero container">
    <p class="hero-label">Solo AI Builder &middot; Austin, TX</p>
    <h1>I build AI systems for communities<br>mainstream tech ignores.</h1>
    <p class="subtitle">
      Former enterprise tech. Now running a solo business entirely through a Claude Code system called Jules.
      Writing about the infrastructure, the thesis, and the playbook.
    </p>
    <div class="hero-links">
      <a href="https://github.com/jonathanmalkin/jules" class="hero-btn">Jules on GitHub</a>
      <a href="/articles/" class="hero-btn hero-btn-outline">Read the Articles</a>
    </div>
  </section>

  <!-- Dashboard: Jules System Stats -->
  <section class="dashboard">
    <div class="dashboard-header">
      <h2>Jules System <span class="pulse">LIVE</span></h2>
      <p class="dashboard-sub">A Claude Code system that runs a solo business. Here's what's inside.</p>
    </div>

    <div class="stat-grid">
      <div class="stat-card">
        <div class="stat-number">33</div>
        <div class="stat-label">Skills</div>
        <div class="stat-detail">Reusable workflows with routing logic, model selection, and skill-to-skill chaining</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">15</div>
        <div class="stat-label">Rules</div>
        <div class="stat-detail">Always-on context: credential lookup, token efficiency, investigation budgets</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">12</div>
        <div class="stat-label">Hooks</div>
        <div class="stat-detail">Deterministic middleware: safety guards, output compression, plan enforcement</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">7</div>
        <div class="stat-label">Cron Jobs</div>
        <div class="stat-detail">VPS running 24/7: morning briefings, tweet scheduling, auth heartbeat</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">12</div>
        <div class="stat-label">Memory Files</div>
        <div class="stat-detail">Persistent context across sessions: feedback, project state, references</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">9</div>
        <div class="stat-label">CLAUDE.md Files</div>
        <div class="stat-detail">Instruction hierarchy four levels deep, from global to project-specific</div>
      </div>
    </div>
  </section>

  <!-- Architecture Diagram -->
  <section class="container" style="margin-bottom: 3rem;">
    <h2>How It Works</h2>
    <div class="arch-diagram">
      <div class="arch-layer">
        <div class="arch-label">Interactive</div>
        <div class="arch-boxes">
          <div class="arch-box">Terminal Session</div>
          <div class="arch-arrow">&rarr;</div>
          <div class="arch-box">Jules Personality</div>
          <div class="arch-arrow">&rarr;</div>
          <div class="arch-box">Skills &amp; Routing</div>
        </div>
      </div>
      <div class="arch-connector">&#8595;</div>
      <div class="arch-layer">
        <div class="arch-label">Middleware</div>
        <div class="arch-boxes">
          <div class="arch-box arch-hook">Safety Guard</div>
          <div class="arch-box arch-hook">Plan Enforcer</div>
          <div class="arch-box arch-hook">Output Compress</div>
          <div class="arch-box arch-hook">Clipboard Validate</div>
        </div>
      </div>
      <div class="arch-connector">&#8595;</div>
      <div class="arch-layer">
        <div class="arch-label">Autonomous</div>
        <div class="arch-boxes">
          <div class="arch-box arch-infra">VPS + Docker</div>
          <div class="arch-arrow">&rarr;</div>
          <div class="arch-box arch-infra">Cron Jobs</div>
          <div class="arch-arrow">&rarr;</div>
          <div class="arch-box arch-infra">Slack Daemon</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Workflow Cards -->
  <section class="container" style="margin-bottom: 3rem;">
    <h2>Daily Workflows</h2>
    <div class="workflow-grid">
      <div class="workflow-card">
        <div class="workflow-icon">&#9728;</div>
        <h3>Morning Briefing</h3>
        <p>5:00 AM. Orchestrator reads operational state, surfaces stale items, checks decision queue, pulls cron job status. Ready before the laptop opens.</p>
      </div>
      <div class="workflow-card">
        <div class="workflow-icon">&#9997;</div>
        <h3>Content Pipeline</h3>
        <p>Five-stage pipeline: Draft &rarr; AI Review &rarr; Human Review &rarr; Approved &rarr; Published. Jules drafts, adapts voice, schedules posts.</p>
      </div>
      <div class="workflow-card">
        <div class="workflow-icon">&#128736;</div>
        <h3>Session Wrap-Up</h3>
        <p>End of every session: commit code, update memory, run self-improvement review, flag publishable content. The system gets smarter each time.</p>
      </div>
      <div class="workflow-card">
        <div class="workflow-icon">&#9888;</div>
        <h3>Decision Framework</h3>
        <p>Every action classified: Just Do It (reversible, within scope) or Ask First (money, external, one-way door). Standing orders earn autonomy over time.</p>
      </div>
    </div>
  </section>

  <!-- Three Stories -->
  <section class="container" style="margin-bottom: 3rem;">
    <h2>What I Write About</h2>
    <div class="story-grid">
      <a href="/jules/" class="story-card story-card-1">
        <div class="story-num">Story 1</div>
        <h3>The Setup Is The Product</h3>
        <p>Claude Code infrastructure, skills, hooks, rules, workflows. The system itself is the work product.</p>
      </a>
      <div class="story-card story-card-2">
        <div class="story-num">Story 2</div>
        <h3>Build Where They Won't</h3>
        <p>The taboo-to-mainstream thesis. Why underserved communities are the next frontier for AI builders.</p>
      </div>
      <div class="story-card story-card-3">
        <div class="story-num">Story 3</div>
        <h3>Solo Founder + AI</h3>
        <p>One person with AI doing what used to require a team. The practical reality, not the hype.</p>
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="container" style="margin-bottom: 3rem;">
    <div class="section-heading">
      <h2>Latest Articles</h2>
      <a href="/articles/">View all &rarr;</a>
    </div>
    {articles.map((article) => (
      <ArticleCard
        title={article.data.title}
        slug={article.id}
        date={article.data.date}
        description={article.data.description}
        story={article.data.story}
      />
    ))}
  </section>
</Base>
