---
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Jonathan Malkin',
  jobTitle: 'AI Automation Consultant',
  description: 'AI automation consultant and product builder helping teams design workflows, internal tools, and operational systems with AI.',
  url: 'https://builtwithjon.com',
  sameAs: [
    'https://github.com/jonathanmalkin',
    'https://x.com/builtwithjon',
    'https://linkedin.com/in/jonathanmalkin',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Jonathan Malkin',
  url: 'https://builtwithjon.com',
  description: 'Jonathan Malkin builds AI systems, automation workflows, and implementation plans for teams with real operational complexity.',
};
---

<Base
  title="Jonathan Malkin"
  description="Jonathan Malkin builds AI systems, automation workflows, and implementation plans for teams with real operational complexity."
  schema={personSchema}
>
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <section class="hero container-wide">
    <p class="eyebrow">Discovery -> Advisory -> Build</p>
    <h1>AI automation systems for operations with real complexity.</h1>
    <p class="subtitle">
      Messy workflows, scattered context, and manual handoffs turned into automation systems people can actually run.
    </p>
    <div class="hero-proof">
      <span class="pill blue">Finance</span>
      <span class="pill sage">HR</span>
      <span class="pill plum">IT</span>
      <span class="pill copper">Operations</span>
      <span class="pill blue">Sales</span>
      <span class="pill sage">Marketing</span>
    </div>
    <div class="hero-links">
      <a href="/workshops/" class="hero-btn">Explore services</a>
      <a href="/projects/" class="hero-btn hero-btn-outline">See project work</a>
    </div>
  </section>

  <section class="container" id="what-i-do" style="margin-bottom: 3rem;">
    <h2>Process</h2>
    <div class="story-grid">
      <a href="/workshops/" class="story-card story-card-1">
        <div class="eyebrow">Discover</div>
        <h3>Find the work worth automating</h3>
        <p>Process workshops, use-case discovery, and opportunity scoring grounded in how the operation actually runs.</p>
      </a>
      <a href="/workshops/" class="story-card story-card-2">
        <div class="eyebrow">Advise</div>
        <h3>Turn ambition into a buildable path</h3>
        <p>Architecture, governance, handoff design, tooling choices, and the operating model needed before automation scales.</p>
      </a>
      <a href="/projects/" class="story-card story-card-3">
        <div class="eyebrow">Build</div>
        <h3>Ship the first working use case</h3>
        <p>Hands-on automation and AI system builds that produce reviewable artifacts, not just demos or decks.</p>
      </a>
    </div>
  </section>

  <section class="container-wide">
    <div class="panel knowledge-home-card">
      <p class="eyebrow">Knowledge OS</p>
      <h2>Knowledge OS is the brains behind the company.</h2>
      <p class="lede">
        It captures signals, keeps raw source material separate from trusted knowledge, routes agent work through review gates, and turns daily operations into artifacts that can be inspected.
      </p>
      <div class="pill-row">
        <span class="pill blue">Signal intake</span>
        <span class="pill sage">Promotion gates</span>
        <span class="pill plum">Review cycles</span>
      </div>
      <div class="diagram-dark">
        <div class="diagram-node"><div class="eyebrow">Input</div><strong>Signals</strong></div>
        <div class="diagram-arrow">-&gt;</div>
        <div class="diagram-node"><div class="eyebrow">System</div><strong>Review + memory</strong></div>
        <div class="diagram-arrow">-&gt;</div>
        <div class="diagram-node"><div class="eyebrow">Output</div><strong>Useful artifacts</strong></div>
      </div>
      <p style="margin-top: 1rem;"><a href="/projects/">See project work &rarr;</a></p>
    </div>
  </section>

  <section class="container" style="margin-bottom: 3rem;">
    <div class="section-heading">
      <h2>Latest Articles</h2>
      <a href="/articles/">View all &rarr;</a>
    </div>
    {articles.map((article) => (
      <ArticleCard
        title={article.data.title}
        slug={article.id}
        date={article.data.date}
        description={article.data.description}
        story={article.data.story}
      />
    ))}
  </section>
</Base>
