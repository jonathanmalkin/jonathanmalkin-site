---
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Jonathan Malkin',
  jobTitle: 'Solo Founder & Technical Advisor',
  description: 'Solo founder of Open Door Learning LLC. Building AI-powered software and tools for communities mainstream tech ignores.',
  url: 'https://builtwithjon.com',
  sameAs: [
    'https://github.com/jonathanmalkin',
    'https://www.reddit.com/user/jonathanmalkin/',
    'https://x.com/builtwithjon',
    'https://linkedin.com/in/jonathanmalkin',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Jonathan Malkin',
  url: 'https://builtwithjon.com',
  description: 'Jonathan Malkin: solo founder building with AI for the communities mainstream tech ignores. 20 years in enterprise tech.',
};
---

<Base
  title="Jonathan Malkin"
  description="Jonathan Malkin: solo founder building with AI for the communities mainstream tech ignores. 20 years in enterprise tech."
  schema={personSchema}
>
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <!-- Hero -->
  <section class="hero container-wide">
    <h1>I solve problems that make other<br/>builders uncomfortable.</h1>
    <p class="subtitle">
      20 years in enterprise tech.<br />Now a solo founder building with AI for the communities mainstream tech ignores.
    </p>
    <div class="hero-links">
      <a href="/articles/" class="hero-btn">Read the Articles</a>
      <a href="/contact/" class="hero-btn hero-btn-outline">Work With Me</a>
    </div>
  </section>

  <!-- What I Do -->
  <section class="container" id="what-i-do" style="margin-bottom: 3rem;">
    <h2>What I Do</h2>
    <div class="story-grid">
      <a href="/jules/" class="story-card story-card-1">
        <h3>Automation &amp; Operations</h3>
        <p>I build systems that handle the work businesses shouldn't do manually. Content pipelines, scheduling, research, reporting. My own business runs on one of these systems. It's open source.</p>
      </a>
      <a href="/projects/" class="story-card story-card-2">
        <h3>Assessment Tools</h3>
        <p>Interactive assessments that help people understand themselves better. Personality frameworks, self-discovery tools, educational content. 200+ daily users on the first one.</p>
      </a>
      <a href="/articles/" class="story-card story-card-3">
        <h3>Writing &amp; Advisory</h3>
        <p>Practitioner articles on AI automation, solo founding, and building for underserved markets. Available for consulting on automation architecture and technical strategy.</p>
      </a>
    </div>
  </section>

  <!-- Three Stories -->
  <section class="container" style="margin-bottom: 3rem;">
    <h2>What I Write About</h2>
    <div class="story-grid">
      <div class="story-card story-card-1">
        <h3>AI Operations</h3>
        <p>How I built an AI operational system that runs a solo business. Infrastructure, automation, the practical details.</p>
      </div>
      <div class="story-card story-card-2">
        <h3>Taboo Markets</h3>
        <p>Why underserved communities are the next frontier. The taboo-to-mainstream trajectory and what it means for builders.</p>
      </div>
      <div class="story-card story-card-3">
        <h3>Team of One</h3>
        <p>One person doing what used to require a team. The practical reality, not the hype.</p>
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="container" style="margin-bottom: 3rem;">
    <div class="section-heading">
      <h2>Latest Articles</h2>
      <a href="/articles/">View all &rarr;</a>
    </div>
    {articles.map((article) => (
      <ArticleCard
        title={article.data.title}
        slug={article.id}
        date={article.data.date}
        description={article.data.description}
        story={article.data.story}
      />
    ))}
  </section>
</Base>
