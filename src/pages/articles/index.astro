---
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base
  title="Articles"
  description="Writing about Claude Code, AI agents, solo founding, and building where mainstream tech won't."
>
  <div class="container">
    <h1>Articles</h1>
    <p style="color: var(--color-text-muted); margin-bottom: 2rem;">
      Long-form writing about AI infrastructure, building as a solo founder, and serving underserved communities with technology.
    </p>
    {articles.map((article) => (
      <ArticleCard
        title={article.data.title}
        slug={article.id}
        date={article.data.date}
        description={article.data.description}
        story={article.data.story}
      />
    ))}
  </div>
</Base>
