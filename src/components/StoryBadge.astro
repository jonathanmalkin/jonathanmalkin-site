---
interface Props {
  story: number;
}

const { story } = Astro.props;

const storyLabels: Record<number, string> = {
  1: 'The Setup Is The Product',
  2: 'Build Where They Won\'t',
  3: 'Solo Founder + AI',
};

const label = storyLabels[story] ?? 'Unknown';
---

<span class={`story-badge story-${story}`}>{label}</span>
