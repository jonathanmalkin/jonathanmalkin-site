---
// Email capture form — POSTs directly to Buttondown. No JS.
---

<section class="email-capture" id="subscribe">
  <h2>Don't miss the next one.</h2>
  <p>
    I write about building a solo business through Claude Code.
    Subscribe and I'll email you when something new goes live. That's it.
  </p>
  <form
    action="https://buttondown.com/api/emails/builtwithjon"
    method="post"
    target="popupwindow"
    class="email-form"
  >
    <input
      type="email"
      name="email"
      placeholder="you@example.com"
      required
      aria-label="Email address"
      class="email-input"
    />
    <button type="submit" class="email-submit">Subscribe</button>
  </form>
</section>
